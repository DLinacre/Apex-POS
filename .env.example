# Apex POS — Environment Configuration
# ======================================
# Copy this file to .env and fill in your values.
# Apex POS runs 100% client-side; these values are embedded at build/deploy time.

# --- Google OAuth (Optional) ---
# Enable Google Sign-In by providing your OAuth 2.0 Client ID.
# Create one at https://console.cloud.google.com/apis/credentials
# Leave blank to keep SSO disabled.
VITE_GOOGLE_CLIENT_ID=

# --- Store Defaults ---
# These override the demo defaults on first load.
VITE_STORE_NAME="Apex Corner Shop"
VITE_STORE_ADDRESS="101 Colmore Row, Birmingham, B3 3AG"
VITE_STORE_PHONE="+44 121 555 0199"
VITE_STORE_EMAIL="contact@apexshop.co.uk"
VITE_CURRENCY="£"
VITE_TAX_RATE=20
VITE_RECEIPT_HEADER="THANK YOU FOR YOUR BUSINESS!"
VITE_RECEIPT_FOOTER="Please keep this receipt. Refunds within 14 days."

# --- Feature Flags ---
# Set to "false" to disable experimental features
VITE_ENABLE_NFC=true
VITE_ENABLE_DEMO_DATA=true
